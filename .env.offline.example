# Config file for docker-compose, don't use for local development
# FastAPI server configuration
API_HOST=0.0.0.0
API_PORT=8000

# Redis connection configuration (for Docker internal network)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_DB_MAIN=0
REDIS_DB_BROKER=1
REDIS_DB_BACKEND=2

# Worker & hardware configuration
GPU_VISIBLE_DEVICES=
ASCEND_RT_VISIBLE_DEVICES=
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
DX_GPU_COUNT=all
DX_ASCEND_IMAGE_NAME=dianxin_auto_train:ascend

# Container image configuration (used by docker-compose + bundle script)
DX_IMAGE_TAG=latest

# File system locations (match the bind mounts defined in docker-compose.yml)
MODEL_OUTPUT_DIR=/app/artifacts
TRAINING_DATA_ROOT=/app/data
# Pre-download base models into ./models and point API requests to /app/models/<model-name>

# ── Offline / air-gapped deployment ──────────────────────────────────────
# Point to local bert-base-chinese so the container never contacts huggingface.co
INFERENCE_BASE_MODEL=/app/models/bert-base-chinese
# Tell HuggingFace / Transformers libraries to never attempt network requests
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Optional external callback integration
EXTERNAL_CALLBACK_BASE_URL=
EXTERNAL_STATUS_CALLBACK_URL=
EXTERNAL_CALLBACK_TIMEOUT=10

# Logging
LOG_LEVEL=INFO
